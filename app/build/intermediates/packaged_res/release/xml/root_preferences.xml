<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- Module Status -->
    <PreferenceCategory
        android:title="Module Status"
        app:iconSpaceReserved="false">

        <SwitchPreferenceCompat
            android:key="module_enabled"
            android:title="Enable Translation"
            android:summary="Turn on to translate UI text in hooked apps"
            android:defaultValue="true"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <!-- Translation Service -->
    <PreferenceCategory
        android:title="Translation Service"
        app:iconSpaceReserved="false">

        <DropDownPreference
            android:key="service_provider"
            android:title="Service Provider"
            android:summary="Choose your translation API"
            android:defaultValue="Gemini"
            app:entries="@array/service_providers"
            app:entryValues="@array/service_provider_values"
            app:iconSpaceReserved="false" />

        <EditTextPreference
            android:key="api_key"
            android:title="API Key"
            android:summary="Enter your API key for the selected service"
            android:dialogTitle="Enter API Key"
            app:iconSpaceReserved="false" />

        <DropDownPreference
            android:key="target_lang"
            android:title="Target Language"
            android:summary="Select the output language"
            android:defaultValue="en"
            app:entries="@array/languages"
            app:entryValues="@array/language_values"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <!-- App Configuration -->
    <PreferenceCategory
        android:title="App Configuration"
        app:iconSpaceReserved="false">

        <EditTextPreference
            android:key="app_whitelist"
            android:title="App Whitelist"
            android:summary="Leave empty to translate all apps"
            android:dialogTitle="App Whitelist"
            android:dialogMessage="Enter package names separated by commas (e.g., com.instagram.android, com.twitter.android)"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <!-- Testing -->
    <PreferenceCategory
        android:title="Testing"
        app:iconSpaceReserved="false">

        <Preference
            android:key="test_connection"
            android:title="Test Connection"
            android:summary="Verify your API key is working"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <!-- About -->
    <PreferenceCategory
        android:title="About"
        app:iconSpaceReserved="false">

        <Preference
            android:key="version"
            android:title="Version"
            android:summary="1.0 (SDK 35)"
            app:iconSpaceReserved="false"
            android:enabled="false" />

        <Preference
            android:key="info"
            android:title="LingoCloud Translator"
            android:summary="Real-time UI translation for Android 15+"
            app:iconSpaceReserved="false"
            android:enabled="false" />

    </PreferenceCategory>

</PreferenceScreen>
