<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- Module Status -->
    <PreferenceCategory
        android:title="Module Status"
        app:iconSpaceReserved="false">

        <SwitchPreferenceCompat
            android:key="module_enabled"
            android:title="Enable Translation"
            android:summary="Turn on to translate UI text in hooked apps"
            android:defaultValue="true"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <!-- Translation Service -->
    <PreferenceCategory
        android:title="Translation Service"
        app:iconSpaceReserved="false">

        <DropDownPreference
            android:key="service_provider"
            android:title="Service Provider"
            android:summary="Choose your translation API"
            android:defaultValue="Gemini"
            app:entries="@array/service_providers"
            app:entryValues="@array/service_provider_values"
            app:iconSpaceReserved="false" />

        <DropDownPreference
            android:key="target_lang"
            android:title="Target Language"
            android:summary="Select the output language"
            android:defaultValue="en"
            app:entries="@array/languages"
            app:entryValues="@array/language_values"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <!-- API Keys -->
    <PreferenceCategory
        android:title="API Keys"
        app:iconSpaceReserved="false">

        <EditTextPreference
            android:key="gemini_api_key"
            android:title="Google Gemini API Key"
            android:summary="Enter your Gemini API key"
            android:dialogTitle="Gemini API Key"
            app:iconSpaceReserved="false" />

        <EditTextPreference
            android:key="microsoft_api_key"
            android:title="Microsoft Translator API Key"
            android:summary="Enter your Microsoft Translator API key"
            android:dialogTitle="Microsoft API Key"
            app:iconSpaceReserved="false" />

        <EditTextPreference
            android:key="gemini_api_key_backup"
            android:title="Backup Google Gemini API Key"
            android:summary="Enter a backup key if the primary exceeds limits"
            android:dialogTitle="Backup Gemini API Key"
            app:iconSpaceReserved="false" />

        <EditTextPreference
            android:key="microsoft_api_key_backup"
            android:title="Backup Microsoft Translator API Key"
            android:summary="Enter a backup key if the primary exceeds limits"
            android:dialogTitle="Backup Microsoft API Key"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <!-- App Configuration -->
    <PreferenceCategory
        android:title="App Configuration"
        app:iconSpaceReserved="false">

        <MultiSelectListPreference
            android:key="app_whitelist"
            android:title="App Whitelist"
            android:summary="Select apps to translate"
            android:dialogTitle="Select Apps"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <!-- Testing -->
    <PreferenceCategory
        android:title="Testing"
        app:iconSpaceReserved="false">

        <Preference
            android:key="test_connection"
            android:title="Test Connection"
            android:summary="Verify your API key is working"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <!-- About -->
    <PreferenceCategory
        android:title="About"
        app:iconSpaceReserved="false">

        <Preference
            android:key="version"
            android:title="Version"
            android:summary="1.1 (SDK 35)"
            app:iconSpaceReserved="false"
            android:enabled="false" />

        <Preference
            android:key="info"
            android:title="LingoCloud Translator"
            android:summary="Real-time UI translation for Android 15+"
            app:iconSpaceReserved="false"
            android:enabled="false" />

    </PreferenceCategory>

</PreferenceScreen>
